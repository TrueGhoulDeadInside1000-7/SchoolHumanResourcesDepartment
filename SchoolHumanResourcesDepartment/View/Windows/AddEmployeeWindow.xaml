<Window x:Class="SchoolHumanResourcesDepartment.View.Windows.AddEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SchoolHumanResourcesDepartment.View.Windows"
        mc:Ignorable="d"
        Title="AddEmployeeWindow" Height="450" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Имя:" Margin="5"/>
        <TextBox Name="FirstNameBox"
                 Grid.Column="1"
                 Margin="5"/>

        <TextBlock Text="Фамилия:"
                   Grid.Row="1"
                   Margin="5"/>
        <TextBox Name="LastNameBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="5"/>

        <TextBlock Text="Телефон:"
                   Grid.Row="2"
                   Margin="5"/>
        <TextBox Name="PhoneBox"
                 Grid.Row="2"
                 Grid.Column="1"
                 Margin="5"/>

        <TextBlock Text="Дата приема:"
                   Grid.Row="3"
                   Margin="5"/>
        <DatePicker Name="HireDatePicker"
                    Grid.Row="3"
                    Grid.Column="1"
                    Margin="5"/>
        <TextBlock Text="Отдел:"
           Grid.Row="4"
           Margin="5"/>

        <ComboBox Name="DepartmentBox"
          Grid.Row="4"
          Grid.Column="1"
          Margin="5"
          DisplayMemberPath="Name"/>


        <TextBlock Text="Должность:"
           Grid.Row="5"
           Margin="5"/>

        <ComboBox Name="PositionBox"
          Grid.Row="5"
          Grid.Column="1"
          Margin="5"
          DisplayMemberPath="Name"/>

        <Button Content="Сохранить"
                Grid.Row="6"
                Grid.ColumnSpan="2"
                Margin="10"
                Click="Save_Click"/>

    </Grid>
</Window>
